# FieldFlow — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Resend (email) ────────────────────────────────────────────
# Found in: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Sender address — must be a verified domain in Resend.
# For demo/testing use: onboarding@resend.dev
EMAIL_FROM=onboarding@resend.dev

# Comma-separated list of admin emails that receive job submission notifications.
ADMIN_EMAILS=cassandra@yourcompany.com,devin@yourcompany.com,kathy@yourcompany.com

# ── App URL ───────────────────────────────────────────────────
# Local development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (update after deploying to Vercel)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
